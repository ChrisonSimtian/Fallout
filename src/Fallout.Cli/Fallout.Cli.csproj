<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RollForward>LatestMajor</RollForward>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>fallout</ToolCommandName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Fallout.Application\Fallout.Application.csproj" />
    <!-- Composition root: references the Infrastructure MSBuild evaluator directly (ProjectModelTasks +
         the IProjectEditor adapter's module initializer). Onion-legal — only the Cli root may reach Infra. -->
    <ProjectReference Include="..\Fallout.Infrastructure.ProjectModel\Fallout.Infrastructure.ProjectModel.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.Common" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="templates\*.cs" />
    <EmbeddedResource Include="templates\*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\.fallout\temp\licenses\*.txt" PackagePath="licenses" Pack="true" Visible="false" />
  </ItemGroup>


  <ItemGroup>
    <ProjectReference Include="..\Fallout.Infrastructure.Tooling\Fallout.Infrastructure.Tooling.csproj" />
  </ItemGroup>


  <ItemGroup>
    <ProjectReference Include="..\Fallout.Infrastructure.Solutions\Fallout.Infrastructure.Solutions.csproj" />
  </ItemGroup>


  <ItemGroup>
    <ProjectReference Include="..\Fallout\Fallout.csproj" />
  </ItemGroup>

</Project>
