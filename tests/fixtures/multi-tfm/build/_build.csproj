<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\..\..\src\Fallout\Fallout.props" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace></RootNamespace>
    <NoWarn>CS0649;CS0169</NoWarn>
    <FalloutRootDirectory>.\..</FalloutRootDirectory>
    <FalloutTelemetryVersion>1</FalloutTelemetryVersion>
    <!-- Skip the package-layout MSBuild-tasks import when consuming from source (see minimal-app). -->
    <FalloutTasksEnabled>False</FalloutTasksEnabled>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Fallout\Fallout.csproj" />
  </ItemGroup>

  <Import Project="..\..\..\..\src\Fallout\Fallout.targets" />

</Project>
