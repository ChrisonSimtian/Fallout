<Project Sdk="Microsoft.NET.Sdk">

  <!-- One-off onion-realignment tool (ADR-0006). Lives under tools/ — outside fallout.slnx and
       outside version.json's pathFilters. Moves types declared in one project to a new namespace
       prefix and fixes references repo-wide, resolving the shared-root ambiguity by type identity. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
  </ItemGroup>

</Project>
